        "import random\n",
        "def JQKA(card_num):\n",
        "  if card_num==11 or card_num==12 or card_num==13:\n",
        "    return 10\n",
        "  elif card_num==14:\n",
        "    return 11\n",
        "  else:\n",
        "    return card_num\n",
        "\n",
        "def totalCard(cardlist):\n",
        "  acecount=0\n",
        "  total=0\n",
        "  for i in range(len(cardlist)):\n",
        "    if cardlist[i]==14:\n",
        "      acecount+=1\n",
        "      if len(cardlist) > 2:\n",
        "        total += 10\n",
        "      else:\n",
        "        total += 11\n",
        "    else:\n",
        "      total+=JQKA(cardlist[i])\n",
        "  while total>21 and acecount>0:\n",
        "    total-=9\n",
        "    acecount-=1\n",
        "  return total\n",
        "def card(type):\n",
